# Скопируйте этот файл в backend/.env и заполните значения.
# ────────────────────────────────────────────────────────────

# Telegram Bot (получить токен у @BotFather в Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Ваш Telegram chat_id (узнать через @userinfobot)
ADMIN_CHAT_ID=123456789

# База данных
# SQLite (для разработки, файл создаётся автоматически):
DATABASE_URL=sqlite+aiosqlite:///./attorney.db
# PostgreSQL (для продакшена):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/attorney_db

# URL сайта (используется в кнопке Telegram-уведомления)
SITE_URL=http://localhost:5173

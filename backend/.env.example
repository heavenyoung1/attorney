# ───────────────────────────────────────────────────────────
# Telegram Bot
# ───────────────────────────────────────────────────────────
# Получить токен у @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Ваш Telegram chat_id (получить через @userinfobot)
ADMIN_CHAT_ID=123456789

# ───────────────────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────────────────
# SQLite (по умолчанию, для разработки):
DATABASE_URL=sqlite+aiosqlite:///./attorney.db

# PostgreSQL (раскомментировать для продакшена):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/attorney_db

# ───────────────────────────────────────────────────────────
# Site URL (используется в кнопке Telegram-сообщения)
# ───────────────────────────────────────────────────────────
SITE_URL=http://localhost:5173
